alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'


# Function to show a simple, colorful directory tree
function ldd() {
    local depth=${1:-2}
    eza --tree --icons --color=always --group-directories-first -L $depth -D -I ".git|node_modules"
}
